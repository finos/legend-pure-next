###Pure
import test::*;

Class test::TPR_Person
{
    firstName : String[1];
    lastName : String[1];
}

//native function <<PCT.function, PCT.platformOnly>> meta::pure::functions::lang::eval<T,V|m,n>(func:Function<{T[n]->V[m]}>[1], param:T[n]):V[m];

function test::testTypeParamResolution<Z|y>(f:Function<{Function<{->Z[y]}>[1]->Z[y]}>[1]):Any[*]
{
    $f->eval(|^TPR_Person(firstName='A', lastName='B')->first()).lastName;
}
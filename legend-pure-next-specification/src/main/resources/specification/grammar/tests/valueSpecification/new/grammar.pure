###Pure
import protocol::support::*;
function protocol::newExpressions(): Any[*]
{
  ^MyClass(name='test');
  ^MyClass(name='hello', value=42);
  [^MyClass(name='a'), ^MyClass(name='b')];
  ^MyClass<String>(name='typed');
  ^MyClass<String|1>(name='typedMult');
}

Class protocol::support::MyClass
{
  name: String[1];
  value: Integer[0..1];
}

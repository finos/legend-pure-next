:classifierGenericType a :Property ;
    :stereotypes :ProtocolInfo_inferred ;
    :name "classifierGenericType" ;
    :classifierGenericType [ :rawType :Property ; :typeArguments ( [ :rawType :Any ] [ :rawType :GenericType ] ) ; :multiplicityArguments :PureOne ] ;
    :owner :Any ;
    :genericType [ :rawType :GenericType ] ;
    :multiplicity :PureOne .

:elementOverride a :Property ;

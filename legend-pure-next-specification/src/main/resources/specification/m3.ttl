@prefix : <https://finos.org/legend/pure/m3#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# CLASSES AND THEIR PROPERTIES
# =============================================================================

# --- Class ---

:Class a :Class ;
    :name "Class" ;
    :classifierGenericType [ :rawType :Class ; :typeArguments [ :rawType :Class ; :typeArguments [ :typeParameter [ :name "T" ] ] ] ] ;
    :package :meta_pure_metamodel_type ;
    :typeParameters [ :name "T" ] ;
    :generalizations 
        [ :general [ :rawType :Type ] ],
        [ :general [ :rawType :PropertyOwner ] ],
        [ :general [ :rawType :ElementWithConstraints ] ],
        [ :general [ :rawType :Testable ] ] .

:qualifiedProperties a :Property ;
    :name "qualifiedProperties" ;
    :classifierGenericType [ :rawType :Property ; :typeArguments ( [ :rawType :PropertyOwner ] [ :rawType :QualifiedProperty ; :typeArguments [ :rawType :Any ] ] ) ; :multiplicityArguments :ZeroMany ] ;
    :owner :PropertyOwner ;
    :genericType [ :rawType :QualifiedProperty ; :typeArguments [ :rawType :Any ] ] ;
    :multiplicity :ZeroMany .

:propertiesFromAssociations a :Property ;
    :stereotypes :ProtocolInfo_inferred, :ProtocolInfo_pointer ;
    :name "propertiesFromAssociations" ;
    :classifierGenericType [ :rawType :Property ; :typeArguments ( [ :rawType :Class ; :typeArguments [ :typeParameter [ :name "T" ] ] ] [ :rawType :Property ; :typeArguments ( [ :typeParameter [ :name "T" ] ] [ :rawType :Any ] ) ; :multiplicityArguments :ZeroMany ] ) ; :multiplicityArguments :ZeroMany ] ;
    :owner :Class ;
    :genericType [ :rawType :Property ; :typeArguments ( [ :typeParameter [ :name "T" ] ] [ :rawType :Any ] ) ; :multiplicityArguments :ZeroMany ] ;
    :multiplicity :ZeroMany .

:qualifiedPropertiesFromAssociations a :Property ;
    :stereotypes :ProtocolInfo_inferred, :ProtocolInfo_pointer ;
    :name "qualifiedPropertiesFromAssociations" ;
    :classifierGenericType [ :rawType :Property ; :typeArguments ( [ :rawType :Class ; :typeArguments [ :typeParameter [ :name "T" ] ] ] [ :rawType :QualifiedProperty ; :typeArguments [ :rawType :Any ] ] ) ; :multiplicityArguments :ZeroMany ] ;
    :owner :Class ;
    :genericType [ :rawType :QualifiedProperty ; :typeArguments [ :rawType :Any ] ] ;
    :multiplicity :ZeroMany .

:typeParameters a :Property ;
    :name "typeParameters" ;
    :classifierGenericType [ :rawType :Property ; :typeArguments ( [ :rawType :Class ; :typeArguments [ :typeParameter [ :name "T" ] ] ] [ :rawType :TypeParameter ] ) ; :multiplicityArguments :ZeroMany ] ;
    :owner :Class ;
    :genericType [ :rawType :TypeParameter ] ;
    :multiplicity :ZeroMany .

:typeVariables a :Property ;
    :name "typeVariables" ;
    :classifierGenericType [ :rawType :Property ; :typeArguments ( [ :rawType :Class ; :typeArguments [ :typeParameter [ :name "T" ] ] ] [ :rawType :VariableExpression ] ) ; :multiplicityArguments :ZeroMany ] ;
    :owner :Class ;
    :genericType [ :rawType :VariableExpression ] ;
    :multiplicity :ZeroMany .

:multiplicityParameters a :Property ;
    :name "multiplicityParameters" ;
    :classifierGenericType [ :rawType :Property ; :typeArguments ( [ :rawType :Class ; :typeArguments [ :typeParameter [ :name "T" ] ] ] [ :rawType :MultiplicityParameter ] ) ; :multiplicityArguments :ZeroMany ] ;
    :owner :Class ;
    :genericType [ :rawType :MultiplicityParameter ] ;
    :multiplicity :ZeroMany .

:originalMilestonedProperties a :Property ;
    :stereotypes :ProtocolInfo_inferred ;
    :name "originalMilestonedProperties" ;
    :classifierGenericType [ :rawType :Property ; :typeArguments ( [ :rawType :PropertyOwner ] [ :rawType :Property ; :typeArguments ( [ :rawType :Nil ] [ :rawType :Any ] ) ; :multiplicityArguments :ZeroMany ] ) ; :multiplicityArguments :ZeroMany ] ;
    :owner :PropertyOwner ;
    :genericType [ :rawType :Property ; :typeArguments ( [ :rawType :Nil ] [ :rawType :Any ] ) ; :multiplicityArguments :ZeroMany ] ;
    :multiplicity :ZeroMany .


:aggregation a :Property ;
    :name "aggregation" ;
    :classifierGenericType [ :rawType :Property ; :typeArguments ( [ :rawType :Property ; :typeArguments ( [ :typeParameter [ :name "U" ; :contravariant true ] ] [ :typeParameter [ :name "V" ] ] ) ] [ :rawType :AggregationKind ] ) ; :multiplicityArguments :PureOne ] ;
    :owner :Property ;
    :genericType [ :rawType :AggregationKind ] ;
    :multiplicity :PureOne .

:prop_defaultValue a :Property ;
    :name "defaultValue" ;
    :classifierGenericType [ :rawType :Property ; :typeArguments ( [ :rawType :Property ; :typeArguments ( [ :typeParameter [ :name "U" ; :contravariant true ] ] [ :typeParameter [ :name "V" ] ] ) ] [ :rawType :LambdaFunction ; :typeArguments [ :rawType [ a :FunctionType ; :returnType [ :typeParameter [ :name "V" ] ] ; :returnMultiplicity :PureOne ] ] ] ) ; :multiplicityArguments :ZeroOne ] ;
    :owner :Property ;
    :genericType [ :rawType :LambdaFunction ; :typeArguments [ :rawType [ a :FunctionType ; :returnType [ :typeParameter [ :name "V" ] ] ; :returnMultiplicity :PureOne ] ] ] ;
    :multiplicity :ZeroOne .

# --- Any ---

:Any a :Class ;
    :name "Any" ;
    :classifierGenericType [ :rawType :Class ; :typeArguments [ :rawType :Any ] ] ;
